# ─── Database ─────────────────────────────────────────────────────────────────
# Local development: SQLite
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# Production (Vercel): set both to Postgres
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://user:password@host:5432/analyst_copilot?schema=public"

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Required for LLM analysis (pipeline) and chat endpoints
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."

# ─── Vercel Blob ──────────────────────────────────────────────────────────────
# Set automatically by Vercel when you add a Blob store to your project.
# For local dev, create a store at https://vercel.com/storage/blob and copy the token.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── Inngest ──────────────────────────────────────────────────────────────────
# Set automatically by the Inngest Vercel integration.
# For local dev, leave empty — the Inngest dev server uses a local bridge.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Optional: External API base URL ─────────────────────────────────────────
# Leave blank to use Next.js API routes at /api/*.
# Set to an external origin if you move the backend separately.
NEXT_PUBLIC_API_URL=""
